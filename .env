SPRING_PROFILES_ACTIVE=dev
# This variable will be used in docker-compose.yml for the Spring app's database connection URL.
DB_NAME=mydatabase
# This variable will be used in docker-compose.yml for the Spring app's database username.
DB_USERNAME=myuser
# This variable will be used in docker-compose.yml for the Spring app's database password.
DB_PASSWORD=mypassword
# This variable will be used in docker-compose.yml for the Spring app's database host.
DB_HOST=postgres-demo-bookshop-service
# This variable will be used in docker-compose.yml for the Spring app's database port.
DB_PORT=5432
# This variable will be used in docker-compose.yml for the Spring app's database connection URL.
DB_URL="jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}"
